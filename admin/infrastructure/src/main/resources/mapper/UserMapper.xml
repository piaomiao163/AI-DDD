<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.piaomiao.dal.mapper.UserMapper">
    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.piaomiao.dal.entity.UserDO">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>
</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.piaomiao.dal.mapper.RoleMapper">
    <!-- 根据编码查询角色 -->
    <select id="selectByCode" parameterType="java.lang.String" resultType="com.piaomiao.dal.entity.RoleDO">
        SELECT * FROM sys_role WHERE code = #{code}
    </select>
    
    <!-- 根据用户ID查询角色 -->
    <select id="selectByUserId" parameterType="java.lang.Long" resultType="com.piaomiao.dal.entity.RoleDO">
        SELECT r.*, ur.user_id as user_id
        FROM sys_role r
        JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>
    
    <!-- 根据用户ID列表查询角色 -->
    <select id="selectByUserIds" parameterType="java.util.List" resultType="com.piaomiao.dal.entity.RoleDO">
        SELECT r.*, ur.user_id as user_id
        FROM sys_role r
        JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id IN
        <foreach collection="userIds" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </select>
    
    <!-- 为角色分配权限 -->
    <insert id="insertRolePermission">
        INSERT INTO sys_role_permission (role_id, permission_id) VALUES (#{roleId}, #{permissionId})
    </insert>
    
    <!-- 删除角色的权限 -->
    <delete id="deleteRolePermissions" parameterType="java.lang.Long">
        DELETE FROM sys_role_permission WHERE role_id = #{roleId}
    </delete>
    
    <!-- 为角色分配菜单 -->
    <insert id="insertRoleMenu">
        INSERT INTO sys_role_menu (role_id, menu_id) VALUES (#{roleId}, #{menuId})
    </insert>
    
    <!-- 删除角色的菜单 -->
    <delete id="deleteRoleMenus" parameterType="java.lang.Long">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>
    
    <!-- 根据角色ID查询权限ID列表 -->
    <select id="selectPermissionIdsByRoleId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT permission_id FROM sys_role_permission WHERE role_id = #{roleId}
    </select>
    
    <!-- 为用户分配角色 -->
    <insert id="insertUserRole">
        INSERT INTO sys_user_role (user_id, role_id) VALUES (#{userId}, #{roleId})
    </insert>
    
    <!-- 删除用户的角色 -->
    <delete id="deleteUserRoles" parameterType="java.lang.Long">
        DELETE FROM sys_user_role WHERE user_id = #{userId}
    </delete>
</mapper>